# Production Environment Variables
NODE_ENV=production
API_PORT=10000
JWT_SECRET=change-me-in-production-use-strong-secret
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?appName=<app-name>
MONGODB_DB_NAME=spms

# Frontend Environment Variables
VITE_API_URL=https://spms-api.onrender.com
